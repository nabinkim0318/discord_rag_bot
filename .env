# ==========================
# Backend (FastAPI)
# ==========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

# Logging
LOG_LEVEL=INFO

# Vector DB / Database Settings (optional)
VECTOR_DB_URL=http://localhost:8080
VECTOR_DB_API_KEY=your-vector-db-api-key
DATABASE_URL=sqlite:///./test.db  # Example (for future DB use)

# LLM Settings (optional)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-3.5-turbo

# RAG Agent Path Settings (optional)
RAG_AGENT_DATA_PATH=./rag_agent/data/

# ==========================
# Frontend (Next.js / React)
# ==========================
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000/api/v1

# ==========================
# Discord Bot (if used later)
# ==========================
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APP_ID=your-discord-app-id

# ==========================
# Docker Compose Environment (optional)
# ==========================
DOCKER_COMPOSE_PROJECT_NAME=discord-rag-bot
